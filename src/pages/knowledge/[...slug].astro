---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
  getPublishedArticles,
  getRelated,
  getStoryFor,
  readingMinutes,
  resolveDates,
  lastModified,
  monthYear,
} from '../../lib/knowledge';
import { articleLd, breadcrumbLd } from '../../lib/schema';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const minutes = readingMinutes(entry.body, d.readingTime);
const all = await getPublishedArticles();
const related = getRelated(entry, all);
const story = await getStoryFor(d.story);
const { published, updated, reviewed } = resolveDates(d);

const dateParts = [
  { label: 'Published', date: published },
  ...(updated ? [{ label: 'Updated', date: updated }] : []),
  ...(reviewed ? [{ label: 'Last reviewed', date: reviewed }] : []),
];

const base = (Astro.site ?? new URL(Astro.url.origin)).href.replace(/\/$/, '');
const pageUrl = `${base}/knowledge/${entry.id}/`;
const image = d.image ?? '/wave-poster.jpg';

const seoTitle = d.seoTitle ?? `${d.title} | Graeme Jones`;
const metaDesc = d.metaDescription ?? d.summary;

// Article + Breadcrumb only. No FAQPage — a single visible Q&A is not a FAQ.
const jsonLd = [
  articleLd({
    base,
    url: pageUrl,
    headline: d.title,
    description: metaDesc,
    section: d.category,
    image: `${base}${image}`,
    datePublished: published.toISOString(),
    dateModified: lastModified(d).toISOString(),
  }),
  breadcrumbLd([
    { name: 'Home', url: `${base}/` },
    { name: 'Knowledge', url: `${base}/knowledge/` },
    { name: d.title, url: pageUrl },
  ]),
];
---

<Base
  title={seoTitle}
  description={metaDesc}
  type="article"
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  canonical={d.canonicalUrl}
  image={image}
  publishedTime={published.toISOString()}
  modifiedTime={lastModified(d).toISOString()}
  section={d.category}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="article" id="main">
    <div class="container article__wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/knowledge/">Knowledge</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{d.title}</span>
      </nav>

      <article class="article__doc">
        <header class="article__head">
          <p class="eyebrow">{d.category}</p>
          <h1>{d.title}</h1>
          <p class="article__dek">{d.dek}</p>
        </header>

        <!-- Answer block: the retrievable core. Question → Short Answer →
             reading time → what the article explains (≤4 points). -->
        <section class="answer" aria-label="Summary">
          <div class="answer__row">
            <span class="answer__label">Question</span>
            <p class="answer__question">{d.question}</p>
          </div>
          <div class="answer__row">
            <span class="answer__label">Short answer</span>
            <p class="answer__short">{d.shortAnswer}</p>
          </div>
          <div class="answer__row">
            <span class="answer__label">Reading time</span>
            <p class="answer__time">{minutes} minute{minutes === 1 ? '' : 's'}</p>
          </div>
          <div class="answer__row">
            <span class="answer__label">This article explains</span>
            <ul class="answer__explains">
              {d.explains.slice(0, 4).map((point) => <li>{point}</li>)}
            </ul>
          </div>
        </section>

        <div class="byline">
          <p class="byline__who">
            By <a href="/#about">Graeme Jones</a> · Executive Advisor, Business &amp; Technology Strategy
          </p>
          <p class="byline__dates">
            {dateParts.map((p) => (
              <time datetime={p.date.toISOString()}>{p.label} {monthYear(p.date)}</time>
            ))}
          </p>
        </div>

        <div class="article__body">
          <Content />
        </div>

        {d.linkedinUrl && (
          <p class="linkedin-note">
            <a href={d.linkedinUrl} target="_blank" rel="noopener noreferrer">
              A related version of this argument is also on LinkedIn
              <span class="ext" aria-hidden="true"> ↗</span>
            </a>
          </p>
        )}
      </article>

      {story && (
        <aside class="fromexp">
          <span class="fromexp__label">From experience</span>
          <a class="fromexp__link" href={`/experience/${story.id}/`}>
            <span class="fromexp__sector">{story.data.category}</span>
            <span class="fromexp__title">{story.data.title}</span>
            <span class="link-arrow">Read the story <span class="btn__arrow" aria-hidden="true">→</span></span>
          </a>
        </aside>
      )}

      {related.length > 0 && (
        <nav class="related" aria-label="Related reading">
          <h2 class="related__head">Related reading</h2>
          <ul class="related__list">
            {related.map((r) => (
              <li>
                <a href={`/knowledge/${r.id}/`}>
                  <span class="related__tag">{r.data.category}</span>
                  <span class="related__q">{r.data.question}</span>
                  <span class="related__sum">{r.data.summary}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <p class="article__all">
        <a class="link-arrow" href="/knowledge/">All executive questions <span class="btn__arrow" aria-hidden="true">→</span></a>
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .article { padding-top: clamp(6.5rem, 11vh, 9rem); padding-bottom: var(--section-y); }
  .article__wrap { max-width: 46rem; }

  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .crumbs a { color: var(--text-muted); }
  .crumbs a:hover { color: var(--teal-deep); }
  .crumbs [aria-current] { color: var(--text); }

  .article__head { margin-bottom: clamp(1.75rem, 4vw, 2.5rem); }
  .article__head h1 {
    font-size: clamp(2.1rem, 4.6vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0.8rem 0 1.1rem;
    text-wrap: balance;
  }
  .article__dek {
    font-size: var(--fs-lead);
    color: var(--text-muted);
    line-height: 1.4;
    max-width: 42ch;
  }

  /* Answer block */
  .answer {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    padding: clamp(1.25rem, 3.5vw, 2.25rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    background: var(--paper-2);
  }
  .answer__row { padding-block: 1rem; border-top: 1px solid var(--line); }
  .answer__row:first-child { padding-top: 0; border-top: none; }
  .answer__row:last-child { padding-bottom: 0; }
  .answer__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 0.5rem;
  }
  .answer__question {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }
  .answer__short { font-size: var(--fs-body-lg); line-height: 1.55; color: var(--text); }
  .answer__time { font-size: var(--fs-body); color: var(--text); }
  .answer__explains { margin: 0; padding-left: 1.1rem; display: grid; gap: 0.4rem; }
  .answer__explains li { color: var(--text-muted); line-height: 1.5; }

  /* Byline + dates */
  .byline {
    margin-bottom: clamp(2.25rem, 4.5vw, 3rem);
    padding-bottom: clamp(1.5rem, 3vw, 2rem);
    border-bottom: 1px solid var(--line);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .byline__who { color: var(--text); }
  .byline__who a { color: var(--teal-deep); text-decoration: underline; text-underline-offset: 2px; }
  .byline__dates { margin-top: 0.35rem; display: flex; flex-wrap: wrap; gap: 0.5rem 0.9rem; }
  .byline__dates time { position: relative; }
  .byline__dates time:not(:first-child)::before {
    content: "·";
    position: absolute;
    left: -0.6rem;
    color: var(--text-faint);
  }

  /* Article body prose */
  .article__body { font-size: var(--fs-body-lg); line-height: 1.72; color: var(--text); }
  .article__body :global(p) { margin-bottom: 1.5rem; }
  .article__body :global(h2) {
    font-size: var(--fs-h3);
    font-weight: 750;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 2.75rem 0 1rem;
  }
  .article__body :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }
  .article__body :global(ul),
  .article__body :global(ol) { margin: 0 0 1.5rem; padding-left: 1.3rem; display: grid; gap: 0.55rem; }
  .article__body :global(li) { line-height: 1.6; }
  .article__body :global(a) {
    color: var(--teal-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--teal-deep) 40%, transparent);
  }
  .article__body :global(a:hover) { text-decoration-color: var(--teal-deep); }
  .article__body :global(strong) { color: var(--text-strong); font-weight: 650; }
  .article__body :global(em) { font-style: italic; }
  .article__body :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--teal);
    color: var(--text-muted);
    font-style: italic;
  }

  .linkedin-note { margin-top: 2rem; font-size: 0.92rem; color: var(--text-muted); }
  .linkedin-note a { color: var(--teal-deep); text-decoration: underline; text-underline-offset: 2px; }

  /* From-experience callout */
  .fromexp {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding-top: 1.75rem;
    border-top: 1px solid var(--line);
  }
  .fromexp__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 0.9rem;
  }
  .fromexp__link { display: grid; gap: 0.35rem; width: fit-content; }
  .fromexp__sector {
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .fromexp__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: -0.015em;
    color: var(--text-strong);
    transition: color 0.2s var(--ease);
  }
  .fromexp__link:hover .fromexp__title { color: var(--teal-deep); }
  .fromexp .link-arrow { margin-top: 0.2rem; }

  /* Related reading */
  .related { margin-top: clamp(3rem, 6vw, 4.5rem); }
  .related__head { font-size: var(--fs-h3); margin-bottom: 1.5rem; }
  .related__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .related__list li { border-top: 1px solid var(--line); }
  .related__list a {
    display: grid;
    gap: 0.4rem;
    padding: 1.4rem 0;
  }
  .related__tag {
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .related__q {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--text-strong);
    transition: color 0.2s var(--ease);
  }
  .related__list a:hover .related__q { color: var(--teal-deep); }
  .related__sum { color: var(--text-muted); font-size: 0.98rem; line-height: 1.5; max-width: 52ch; }

  .article__all { margin-top: clamp(2.5rem, 5vw, 3.5rem); }

  /* Mobile: keep the answer panel from dominating the first viewport. */
  @media (max-width: 640px) {
    .answer { padding: 1.1rem 1.15rem; border-radius: var(--radius-sm); }
    .answer__row { padding-block: 0.75rem; }
    .answer__label { margin-bottom: 0.3rem; }
    .answer__question { font-size: 1.2rem; }
    .answer__short { font-size: var(--fs-body); }
    .answer__explains { gap: 0.3rem; }
  }
</style>
