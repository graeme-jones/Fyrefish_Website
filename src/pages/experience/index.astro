---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getPublishedStories, readingMinutes } from '../../lib/knowledge';
import { collectionPageLd } from '../../lib/schema';

const stories = await getPublishedStories();

const base = (Astro.site ?? new URL(Astro.url.origin)).href.replace(/\/$/, '');
const description =
  'The engagements that shaped how I think about technology, product and business transformation — where the principles behind this practice were actually earned.';

const jsonLd = collectionPageLd({
  base,
  url: `${base}/experience/`,
  name: 'Experience — where these ideas came from',
  description,
  items: stories.map((s) => ({ name: s.data.title, url: `${base}/experience/${s.id}/` })),
});
---

<Base title="Experience — Where these ideas came from | Fyrefish" description={description} jsonLd={jsonLd}>
  <Nav />
  <main class="exp" id="main">
    <div class="container">
      <header class="exp__head">
        <p class="eyebrow reveal">Experience</p>
        <h1 class="reveal" data-delay="1">Where these ideas came from.</h1>
        <p class="lead reveal" data-delay="1">
          The principles behind this practice weren't developed in a boardroom. They were earned
          solving real business problems — often very different from the ones clients thought they had.
        </p>
      </header>

      <ul class="exp__list">
        {stories.map((s) => (
          <li class="reveal">
            <article class="scard">
              <p class="scard__cat">{s.data.category}</p>
              <a class="scard__title" href={`/experience/${s.id}/`}>{s.data.title}</a>
              <p class="scard__hook">{s.data.hook[0]}</p>
              <p class="scard__intro">{s.data.intro}</p>
              <p class="scard__foot">
                <a class="link-arrow" href={`/experience/${s.id}/`}>Read the story <span class="btn__arrow" aria-hidden="true">→</span></a>
                <span class="scard__read">{readingMinutes(s.body, s.data.readingTime)} min read</span>
              </p>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .exp { padding-top: clamp(8rem, 14vh, 11rem); padding-bottom: var(--section-y); }
  .exp__head { max-width: 46ch; margin-bottom: clamp(3.5rem, 7vw, 5.5rem); }
  .exp__head h1 { font-size: var(--fs-h2); margin-bottom: 1.2rem; }
  .exp__head .lead { max-width: 54ch; }

  .exp__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .exp__list > li { border-top: 1px solid var(--line); }
  .scard { padding: clamp(2rem, 4.5vw, 3.25rem) 0; display: grid; gap: 0.7rem; }
  .scard__cat {
    font-size: 0.74rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .scard__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--text-strong);
    max-width: 20ch;
    transition: color 0.2s var(--ease);
  }
  .scard__title:hover { color: var(--teal-deep); }
  .scard__hook {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 1.7vw, 1.3rem);
    color: var(--text);
    max-width: 34ch;
  }
  .scard__intro { color: var(--text-muted); font-size: var(--fs-body-lg); line-height: 1.6; max-width: 62ch; }
  .scard__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem 1.5rem;
    margin-top: 0.3rem;
  }
  .scard__read { font-size: 0.85rem; color: var(--text-faint); }
</style>
