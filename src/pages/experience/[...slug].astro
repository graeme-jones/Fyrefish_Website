---
import { render, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
  getPublishedStories,
  readingMinutes,
  resolveDates,
  lastModified,
  monthYear,
} from '../../lib/knowledge';
import { articleLd, breadcrumbLd } from '../../lib/schema';

export async function getStaticPaths() {
  const stories = await getPublishedStories();
  return stories.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const minutes = readingMinutes(entry.body, d.readingTime);
const { published, updated, reviewed } = resolveDates(d);
const dateParts = [
  { label: 'Published', date: published },
  ...(updated ? [{ label: 'Updated', date: updated }] : []),
  ...(reviewed ? [{ label: 'Last reviewed', date: reviewed }] : []),
];

// "The idea behind this story" — the principles this experience seeded.
const ideas = (
  await Promise.all(d.relatedKnowledge.map((slug) => getEntry('articles', slug)))
).filter((a) => a && !a.data.draft);

const base = (Astro.site ?? new URL(Astro.url.origin)).href.replace(/\/$/, '');
const pageUrl = `${base}/experience/${entry.id}/`;
const image = d.image ?? '/wave-poster.jpg';
const seoTitle = d.seoTitle ?? `${d.title} | Graeme Jones`;
const metaDesc = d.metaDescription ?? d.intro;

const jsonLd = [
  articleLd({
    base,
    url: pageUrl,
    headline: d.title,
    description: metaDesc,
    section: d.category,
    image: `${base}${image}`,
    datePublished: published.toISOString(),
    dateModified: lastModified(d).toISOString(),
  }),
  breadcrumbLd([
    { name: 'Home', url: `${base}/` },
    { name: 'Experience', url: `${base}/experience/` },
    { name: d.title, url: pageUrl },
  ]),
];
---

<Base
  title={seoTitle}
  description={metaDesc}
  type="article"
  ogTitle={d.ogTitle}
  ogDescription={d.ogDescription}
  canonical={d.canonicalUrl}
  image={image}
  publishedTime={published.toISOString()}
  modifiedTime={lastModified(d).toISOString()}
  section={d.category}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="story-page" id="main">
    <div class="container story-page__wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/experience/">Experience</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{d.title}</span>
      </nav>

      <article class="story-page__doc">
        <header class="story-page__head">
          <p class="eyebrow">{d.category}</p>
          <h1>{d.title}</h1>
        </header>

        <div class="story-open">
          {d.hook.map((line) => <p>{line}</p>)}
        </div>

        <div class="byline">
          <p class="byline__who">
            By <a href="/#about">Graeme Jones</a> · Executive Advisor, Business &amp; Technology Strategy
          </p>
          <p class="byline__dates">
            {dateParts.map((p) => (
              <time datetime={p.date.toISOString()}>{p.label} {monthYear(p.date)}</time>
            ))}
            <span class="byline__read">{minutes} min read</span>
          </p>
        </div>

        <div class="story-body">
          <Content />
        </div>

        <div class="story-lesson">
          <span class="story-lesson__label">What this taught me</span>
          {d.lesson.map((p) => <p>{p}</p>)}
        </div>
      </article>

      {ideas.length > 0 && (
        <nav class="idea" aria-label="The idea behind this story">
          <span class="idea__label">The idea behind this story</span>
          <ul class="idea__list">
            {ideas.map((a) => (
              <li>
                <a href={`/knowledge/${a.id}/`}>
                  <span class="idea__tag">{a.data.category}</span>
                  <span class="idea__q">{a.data.question}</span>
                  <span class="idea__sum">{a.data.summary}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <p class="story-page__all">
        <a class="link-arrow" href="/experience/">All experience stories <span class="btn__arrow" aria-hidden="true">→</span></a>
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .story-page { padding-top: clamp(6.5rem, 11vh, 9rem); padding-bottom: var(--section-y); }
  .story-page__wrap { max-width: 44rem; }

  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .crumbs a { color: var(--text-muted); }
  .crumbs a:hover { color: var(--teal-deep); }
  .crumbs [aria-current] { color: var(--text); }

  .story-page__head h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.03;
    letter-spacing: -0.03em;
    margin: 0.8rem 0 0;
    max-width: 18ch;
    text-wrap: balance;
  }

  /* Cold open — the hook. Larger, on a narrower measure, closed by a rule. */
  .story-open {
    max-width: 34ch;
    margin: clamp(1.75rem, 4vw, 2.5rem) 0;
    padding-bottom: clamp(1.75rem, 3.5vw, 2.25rem);
    border-bottom: 1px solid var(--line-strong);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    line-height: 1.4;
    letter-spacing: -0.018em;
    color: var(--text-strong);
    font-weight: 450;
  }
  .story-open p + p { margin-top: 0.7em; }

  .byline {
    margin-bottom: clamp(2.25rem, 4.5vw, 3rem);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .byline__who { color: var(--text); }
  .byline__who a { color: var(--teal-deep); text-decoration: underline; text-underline-offset: 2px; }
  .byline__dates { margin-top: 0.35rem; display: flex; flex-wrap: wrap; gap: 0.5rem 0.9rem; }
  .byline__dates time, .byline__read { position: relative; }
  .byline__dates > *:not(:first-child)::before {
    content: "·";
    position: absolute;
    left: -0.6rem;
    color: var(--text-faint);
  }

  /* Narrative body */
  .story-body { font-size: var(--fs-body-lg); line-height: 1.75; color: var(--text); }
  .story-body :global(p) { margin-bottom: 1.4rem; }
  .story-body :global(p:last-child) { margin-bottom: 0; }
  .story-body :global(a) {
    color: var(--teal-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .story-body :global(em) { font-style: italic; }
  .story-body :global(strong) { color: var(--text-strong); font-weight: 650; }

  /* "What this taught me" */
  .story-lesson {
    margin-top: clamp(2.5rem, 4vw, 3.25rem);
    padding-top: clamp(1.5rem, 2.5vw, 2rem);
    border-top: 1px solid var(--line-strong);
    max-width: 48ch;
  }
  .story-lesson__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 1rem;
  }
  .story-lesson p {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.9vw, 1.45rem);
    line-height: 1.4;
    color: var(--text-strong);
    letter-spacing: -0.015em;
  }
  .story-lesson p + p {
    margin-top: 0.9rem;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: 1.6;
    color: var(--text-muted);
    letter-spacing: normal;
  }

  /* The idea behind this story */
  .idea { margin-top: clamp(3rem, 6vw, 4.5rem); }
  .idea__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal-deep);
    margin-bottom: 1rem;
  }
  .idea__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .idea__list li { border-top: 1px solid var(--line); }
  .idea__list a { display: grid; gap: 0.4rem; padding: 1.35rem 0; }
  .idea__tag {
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .idea__q {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--text-strong);
    transition: color 0.2s var(--ease);
  }
  .idea__list a:hover .idea__q { color: var(--teal-deep); }
  .idea__sum { color: var(--text-muted); font-size: 0.98rem; line-height: 1.5; max-width: 52ch; }

  .story-page__all { margin-top: clamp(2.5rem, 5vw, 3.5rem); }
</style>
