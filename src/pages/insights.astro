---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const articles = [
  {
    title: 'AI Isn’t Replacing Software Engineers. It’s Changing the Economics of Software Development.',
    desc: 'How AI changes software economics, team structures and what executive leadership should actually be preparing for.',
    href: 'https://www.linkedin.com/posts/graeme-jones-fyrefish_over-the-past-few-months-ive-found-myself-ugcPost-7480450376828088321-1Qua',
  },
  {
    title: 'What Happens When Custom Software Becomes Cheaper Than SaaS?',
    desc: 'As AI reduces the cost of software creation, the economics of buying versus building begin to change dramatically.',
    href: 'https://www.linkedin.com/posts/graeme-jones-fyrefish_ugcPost-7482287812826980352-mQfu/',
  },
];
---

<Base
  title="Insights — Fyrefish Technologies"
  description="Perspectives on business operating models, product strategy, AI and enterprise technology, by Graeme Jones."
>
  <Nav />
  <main class="insights" id="main">
    <div class="container">
      <header class="insights__head">
        <p class="eyebrow reveal">Insights</p>
        <h1 class="reveal" data-delay="1">Perspectives on strategy, technology &amp; the economics of software.</h1>
        <p class="lead reveal" data-delay="1">
          Notes on business operating models, product strategy, AI and enterprise technology.
        </p>
      </header>

      <ul class="insights__list">
        {articles.map((a, i) => (
          <li class="reveal" data-delay={i}>
            <a class="insight" href={a.href} target="_blank" rel="noopener noreferrer">
              <span class="insight__tag">Article · LinkedIn</span>
              <h2 class="insight__title">{a.title}</h2>
              <p class="insight__desc">{a.desc}</p>
              <span class="link-arrow">Read on LinkedIn <span class="btn__arrow" aria-hidden="true">→</span></span>
            </a>
          </li>
        ))}
      </ul>

      <p class="insights__more reveal">
        More writing on <a class="link-arrow" href="https://www.linkedin.com/in/graeme-jones-fyrefish" target="_blank" rel="noopener noreferrer">LinkedIn <span class="btn__arrow" aria-hidden="true">→</span></a>
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .insights { padding-top: clamp(8rem, 14vh, 11rem); padding-bottom: var(--section-y); }
  .insights__head { max-width: 44ch; margin-bottom: clamp(3rem, 6vw, 4.5rem); }
  .insights__head h1 { font-size: var(--fs-h2); margin-bottom: 1.1rem; }
  .insights__head .lead { max-width: 50ch; }

  .insights__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  .insight {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: 1.75rem;
    border-top: 1px solid var(--line-strong);
  }
  .insight__tag {
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.5rem;
  }
  .insight__title {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    line-height: 1.12;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    transition: color 0.2s var(--ease);
  }
  .insight:hover .insight__title { color: var(--teal-deep); }
  .insight__desc { color: var(--text-muted); margin-bottom: 1.75rem; max-width: 40ch; }
  .insight .link-arrow { margin-top: auto; }

  .insights__more { margin-top: clamp(3rem, 5vw, 4.5rem); color: var(--text-muted); }

  @media (max-width: 720px) {
    .insights__list { grid-template-columns: 1fr; }
  }
</style>
