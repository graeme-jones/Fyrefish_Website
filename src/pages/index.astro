---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhyItMatters from '../components/WhyItMatters.astro';
import Framework from '../components/Framework.astro';
import Patterns from '../components/Patterns.astro';
import Statement from '../components/Statement.astro';
import Review from '../components/Review.astro';
import Experience from '../components/Experience.astro';
import About from '../components/About.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { siteGraph } from '../lib/schema';

const base = (Astro.site ?? new URL(Astro.url.origin)).href.replace(/\/$/, '');
const jsonLd = siteGraph(base, `${base}/wave-poster.jpg`);
---

<Base jsonLd={jsonLd}>
  <Nav overHero={true} />
  <main>
    <Hero />
    <WhyItMatters />
    <Framework />
    <Patterns />
    <Statement />
    <Review />
    <Experience />
    <About />
    <FinalCta />
  </main>
  <Footer />
</Base>
