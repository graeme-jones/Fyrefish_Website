---
const CONTACT_EMAIL = 'graeme.jones@fyrefish.com';
const subject = encodeURIComponent('Business Operating Model Review — enquiry');
const mailto = `mailto:${CONTACT_EMAIL}?subject=${subject}`;
---

<section class="section section--dark cta" id="contact">
  <div class="cta__bg" aria-hidden="true"></div>
  <div class="container cta__inner">
    <p class="eyebrow on-dark reveal" style="justify-content:center">Before your next decision</p>
    <h2 class="cta__title reveal" data-delay="1">
      Have the conversation before you commit the budget.
    </h2>
    <p class="cta__sub reveal" data-delay="1">
      A short, focused engagement that brings clarity to your next major technology, AI or automation
      decision — and confidence to the leadership team making it.
    </p>
    <div class="cta__actions reveal" data-delay="2">
      <a class="btn btn--primary btn--lg" href={mailto}>
        Book a discussion <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--on-dark btn--lg" href="#review">See what's included</a>
    </div>
    <p class="cta__contact reveal" data-delay="2">
      Or email directly — <a href={mailto}>{CONTACT_EMAIL}</a>
    </p>
  </div>
</section>

<style>
  .cta { position: relative; overflow: hidden; text-align: center; background: var(--ink-2); }
  .cta__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 60% at 50% 0%, rgba(44,138,134,0.28), transparent 70%),
      radial-gradient(50% 50% at 85% 100%, rgba(224,74,58,0.16), transparent 70%);
  }
  .cta__inner { position: relative; max-width: 760px; }
  .cta__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 16ch;
    margin-inline: auto;
  }
  .cta__sub {
    font-size: var(--fs-lead);
    color: var(--text-on-dark-muted);
    line-height: 1.55;
    max-width: 48ch;
    margin: 0 auto 2.5rem;
  }
  .cta__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; justify-content: center; }
  .cta__contact { margin-top: 1.75rem; color: var(--text-on-dark-faint); font-size: 0.95rem; }
  .cta__contact a { color: var(--teal-bright); }
  .cta__contact a:hover { text-decoration: underline; }
</style>
