---
import { CAL_LINK } from '../lib/site-links';
const CONTACT_EMAIL = 'graeme.jones@fyrefish.com';
const subject = encodeURIComponent('Business Operating Model Review — enquiry');
const mailto = `mailto:${CONTACT_EMAIL}?subject=${subject}`;
---

<section class="section section--dark cta" id="contact">
  <div class="cta__bg" aria-hidden="true"></div>
  <div class="container cta__inner">
    <h2 class="cta__title reveal">
      The conversation to have before the decision — not after it.
    </h2>
    <p class="cta__sub reveal" data-delay="1">
      A few focused weeks, before the next major technology, AI or automation commitment.
    </p>
    <div class="cta__actions reveal" data-delay="2">
      <a class="btn btn--primary btn--lg" href={CAL_LINK} target="_blank" rel="noopener noreferrer">
        Book a 30-min call <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <p class="cta__contact reveal" data-delay="2">
      Or email <a href={mailto}>{CONTACT_EMAIL}</a>
    </p>
  </div>
</section>

<style>
  .cta { position: relative; overflow: hidden; text-align: center; background: var(--ink-2); }
  .cta__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(55% 55% at 50% 8%, rgba(44,138,134,0.22), transparent 70%);
  }
  .cta__inner { position: relative; max-width: 800px; }
  .cta__title {
    font-size: clamp(2.3rem, 5.2vw, 3.9rem);
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-bottom: 1.75rem;
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta__sub {
    font-size: var(--fs-lead);
    color: var(--text-on-dark-muted);
    line-height: 1.55;
    max-width: 42ch;
    margin: 0 auto 2.75rem;
  }
  .cta__actions { display: flex; justify-content: center; }
  .cta__contact { margin-top: 1.75rem; font-size: 0.95rem; }
  .cta__contact a { color: var(--teal-bright); }
  .cta__contact a:hover { text-decoration: underline; }
</style>
