---
const steps = [
  {
    n: '01',
    title: 'Understand the Business',
    items: 'Strategic objectives · Competitive differentiation · Customer journeys · Business outcomes · Operational challenges',
    note: 'Technology is deliberately left out of the conversation.',
  },
  {
    n: '02',
    title: 'Assess the Current Model',
    items: 'Decision making · Information flow · Business capabilities · Existing systems · Operational bottlenecks',
    note: "The objective isn't criticism — it's understanding.",
  },
  {
    n: '03',
    title: 'Design the Future Model',
    items: 'Eliminate complexity · Redesign workflows · Identify automation · Clarify responsibilities',
    note: '"If we were building this business today, how would we want it to operate?"',
  },
  {
    n: '04',
    title: 'Prioritize Opportunities',
    items: 'Quick wins · Strategic initiatives · AI & automation · Build vs. buy decisions',
    note: 'Not every improvement deserves to be implemented.',
  },
  {
    n: '05',
    title: 'Recommendations',
    items: 'Business improvements · Process changes · Solution recommendations · AI opportunities · Next steps',
    note: "The objective isn't more software. It's a better business.",
    accent: true,
  },
];
---

<section class="section process" id="process">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">The Process</p>
      <h2>What to Expect</h2>
      <p class="lead">
        Every organization is different, but every review follows the same progression — because every
        successful transformation begins by understanding the business before deciding on the technology.
      </p>
    </div>

    <ol class="process__list">
      {steps.map((s) => (
        <li class="process__step reveal">
          <span class={`process__n${s.accent ? ' process__n--accent' : ''}`}>{s.n}</span>
          <div class="process__body">
            <h3>{s.title}</h3>
            <p class="process__items">{s.items}</p>
            <p class="process__note">{s.note}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process__list { list-style: none; padding: 0; display: grid; gap: 1rem; }
  .process__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 3vw, 1.75rem);
    align-items: start;
    background: var(--paper-2);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2rem);
  }
  .process__n {
    display: grid;
    place-items: center;
    width: 56px; height: 56px;
    flex: none;
    background: var(--teal);
    color: #fff;
    border-radius: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
  }
  .process__n--accent { background: var(--coral); }
  .process__body h3 { font-size: 1.4rem; margin-bottom: 0.6rem; }
  .process__items { color: var(--text-muted); margin-bottom: 0.75rem; }
  .process__note {
    color: var(--teal);
    font-weight: 700;
    font-style: italic;
    font-family: var(--font-display);
    font-size: 1.02rem;
  }
  @media (max-width: 520px) {
    .process__step { grid-template-columns: 1fr; }
    .process__n { width: 48px; height: 48px; font-size: 1.1rem; }
  }
</style>
