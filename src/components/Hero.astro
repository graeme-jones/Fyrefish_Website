---
// Hero — full-bleed light-thread motion on black, executive headline over it.
---

<section class="hero" id="main">
  <div class="hero__media" aria-hidden="true">
    <video
      class="hero__wave"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/wave-poster.jpg"
    >
      <source src="/wave.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="container hero__grid">
    <div class="hero__content">
      <p class="eyebrow on-dark reveal">Executive Advisory</p>
      <h1 class="hero__title reveal" data-delay="1">
        Better technology decisions begin with a clearer understanding of the business.
      </h1>
      <p class="hero__sub reveal" data-delay="2">
        Fyrefish helps executive teams understand how their business should operate — before
        committing to a major technology, AI or automation investment.
      </p>
      <div class="hero__cta reveal" data-delay="3">
        <a class="btn btn--primary btn--lg" href="#contact">
          Book a discussion <span class="btn__arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--on-dark btn--lg" href="#why">How the review works</a>
      </div>
      <div class="hero__by reveal" data-delay="3">
        <span class="hero__by-name">Graeme Jones</span>
        <span class="hero__by-role">Executive Advisor · Business &amp; Technology Strategy</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Pure black so the video's own black background is seamless — no visible box. */
  .hero {
    position: relative;
    background: #000;
    color: var(--text-on-dark);
    overflow: hidden;
  }

  /* Full-bleed motion layer, centred. Spans the full viewport width so the clip's
     baked-in left/right fades land at the screen edges on any monitor size. */
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .hero__wave {
    width: 100%;
    max-width: none;
    height: auto;
  }

  /* Keeps the headline legible over the thread motion and grounds the section. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, #000 0%, rgba(0,0,0,0.74) 30%, rgba(0,0,0,0) 60%),
      linear-gradient(0deg, rgba(0,0,0,0.65) 0%, transparent 26%),
      radial-gradient(120% 80% at 50% 50%, transparent 55%, rgba(0,0,0,0.55) 100%);
  }

  .hero__grid {
    position: relative;
    z-index: 2;
    display: grid;
    align-items: center;
    padding-block: clamp(8rem, 15vh, 11rem) clamp(4.5rem, 9vw, 7rem);
    min-height: 760px;
  }
  .hero__content { max-width: 44rem; }
  .hero__title {
    color: var(--text-on-dark);
    font-size: var(--fs-display);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.0;
    margin-bottom: 1.75rem;
    max-width: 17ch;
  }
  .hero__sub {
    font-size: clamp(1.15rem, 1.7vw, 1.35rem);
    line-height: 1.55;
    color: var(--text-on-dark-muted);
    max-width: 42ch;
    margin-bottom: 2.5rem;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-bottom: 3rem; }

  .hero__by {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1.1rem;
    border-left: 2px solid var(--coral);
    width: fit-content;
  }
  .hero__by-name { font-family: var(--font-display); font-weight: 700; font-size: 1.02rem; }
  .hero__by-role { color: var(--text-on-dark-muted); font-size: 0.9rem; }

  @media (max-width: 900px) {
    .hero__grid {
      min-height: 620px;
      padding-block: clamp(8rem, 20vh, 10rem) clamp(3.5rem, 8vw, 5rem);
    }
    .hero__wave { width: 130%; }
    /* Stronger vertical scrim on narrow screens where text sits over the threads. */
    .hero__scrim {
      background:
        linear-gradient(0deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.35) 42%, transparent 70%),
        radial-gradient(120% 80% at 50% 40%, transparent 45%, rgba(0,0,0,0.6) 100%);
    }
  }

  /* Respect reduced-motion: the JS below pauses playback; the poster frame remains. */
  @media (prefers-reduced-motion: reduce) {
    .hero__wave { /* first frame / poster stays visible, no motion */ }
  }
</style>

<script>
  // Honour prefers-reduced-motion — pause the ambient loop, keep the still frame.
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('video.hero__wave').forEach((v) => {
      v.removeAttribute('autoplay');
      v.pause();
    });
  }
</script>
