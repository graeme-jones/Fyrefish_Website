---
// Homepage Experience section — compact cards only. Full narratives live on
// dedicated pages at /experience/<slug>/. Keeps the homepage short on mobile.
import { getPublishedStories, readingMinutes } from '../lib/knowledge';

const stories = await getPublishedStories();
---

<section class="section section--dark experience" id="experience">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow on-dark">Experience</p>
      <h2>Where These Ideas Came From</h2>
      <p class="lead">The ideas on this site weren't developed in a boardroom. They were earned solving real business problems — often very different from the ones clients thought they had.</p>
    </div>

    <ul class="xcards">
      {stories.map((s) => (
        <li class="reveal">
          <article class="xcard">
            <p class="xcard__cat">{s.data.category}</p>
            <a class="xcard__title" href={`/experience/${s.id}/`}>{s.data.title}</a>
            <p class="xcard__hook">{s.data.hook[0]}</p>
            <p class="xcard__excerpt">{s.data.homepageExcerpt}</p>
            <p class="xcard__foot">
              <a class="link-arrow" href={`/experience/${s.id}/`}>Read the story <span class="btn__arrow" aria-hidden="true">→</span></a>
              <span class="xcard__read">{readingMinutes(s.body, s.data.readingTime)} min read</span>
            </p>
          </article>
        </li>
      ))}
    </ul>

    <p class="experience__all reveal">
      <a class="link-arrow" href="/experience/">All experience stories <span class="btn__arrow" aria-hidden="true">→</span></a>
    </p>
  </div>
</section>

<style>
  .xcards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .xcards > li { border-top: 1px solid var(--ink-hair); }
  .xcard {
    display: grid;
    grid-template-columns: minmax(0, 0.32fr) minmax(0, 1.68fr);
    gap: clamp(1rem, 4vw, 3.5rem);
    padding: clamp(2.25rem, 4.5vw, 3.5rem) 0;
    align-items: start;
  }
  .xcard__cat {
    grid-column: 1;
    padding-top: 0.5rem;
    font-weight: 650;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal-bright);
  }
  .xcard__title {
    grid-column: 2;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--text-on-dark);
    max-width: 20ch;
    transition: color 0.2s var(--ease);
  }
  .xcard__title:hover { color: var(--teal-bright); }
  .xcard__hook {
    grid-column: 2;
    margin-top: 0.9rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.15rem, 1.9vw, 1.4rem);
    line-height: 1.35;
    color: var(--text-on-dark);
    max-width: 32ch;
  }
  .xcard__excerpt {
    grid-column: 2;
    margin-top: 0.9rem;
    color: var(--text-on-dark-muted);
    font-size: clamp(1.02rem, 1.4vw, 1.15rem);
    line-height: 1.6;
    max-width: 56ch;
  }
  .xcard__foot {
    grid-column: 2;
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 1.4rem;
  }
  .xcard__foot .link-arrow { color: var(--teal-bright); }
  .xcard__read { font-size: 0.82rem; color: var(--text-on-dark-faint); }

  .experience__all { margin-top: clamp(2.5rem, 5vw, 3.5rem); }
  .experience__all .link-arrow { color: var(--teal-bright); }

  @media (max-width: 760px) {
    .xcard { grid-template-columns: 1fr; gap: 0.55rem; }
    .xcard__cat { grid-column: 1; padding-top: 0; margin-bottom: 0.4rem; }
    .xcard__title, .xcard__hook, .xcard__excerpt, .xcard__foot { grid-column: 1; }
  }
</style>
