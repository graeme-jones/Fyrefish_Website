---
const patterns = [
  {
    n: '01',
    title: 'Reporting without insight',
    body: "Leaders get reports every month, yet still can't answer simple questions — where costs are rising, which customers drive them, which activities actually create value.",
    take: 'The data exists. The insight doesn\'t.',
  },
  {
    n: '02',
    title: 'Software driving the business',
    body: 'Processes quietly reshape themselves around the limits of the tools, until the software has quietly become the operating model.',
    take: 'The tail begins to wag the dog.',
  },
  {
    n: '03',
    title: 'AI before strategy',
    body: 'The question is rarely “how do we use AI?” The better one is “where would better decisions create the most value?” — and it comes first.',
    take: 'AI compounds clarity, and confusion.',
  },
];
---

<section class="section patterns" id="patterns">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Recurring Patterns</p>
      <h2>The same three signals, again and again.</h2>
      <p class="lead">
        Different industries, different scale — the underlying pattern rarely changes.
      </p>
    </div>

    <div class="patterns__grid">
      {patterns.map((p, i) => (
        <article class="pattern reveal" data-delay={i}>
          <span class="pattern__n">{p.n}</span>
          <h3>{p.title}</h3>
          <p class="pattern__body">{p.body}</p>
          <p class="pattern__take">{p.take}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .patterns__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3.5vw, 3rem);
  }
  .pattern {
    padding-top: 1.5rem;
    border-top: 2px solid var(--text-strong);
  }
  .pattern__n {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--coral);
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }
  .pattern h3 { font-size: var(--fs-h3); margin-bottom: 0.9rem; }
  .pattern__body { color: var(--text-muted); margin-bottom: 1.5rem; }
  .pattern__take {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--teal);
    letter-spacing: -0.01em;
  }
  @media (max-width: 820px) {
    .patterns__grid { grid-template-columns: 1fr; gap: 2.25rem; }
    .pattern { padding-top: 1.25rem; }
  }
</style>
