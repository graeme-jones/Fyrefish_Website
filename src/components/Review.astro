---
const deliverables = [
  { n: '01', title: 'Executive Briefing', desc: 'Findings and recommendations, distilled.' },
  { n: '02', title: 'Operating Model Assessment', desc: 'How the business runs today — and where it should evolve.' },
  { n: '03', title: 'Capability Assessment', desc: 'What genuinely differentiates you.' },
  { n: '04', title: 'AI & Automation Assessment', desc: "Where AI creates measurable value — and where it doesn't." },
  { n: '05', title: 'Build vs. Buy Recommendations', desc: 'Where to build, buy, automate or simplify.' },
  { n: '06', title: '12–18 Month Roadmap', desc: 'A prioritized sequence, ordered by business value.' },
];

const facts = [
  { k: '2–3 weeks', v: 'Typical engagement' },
  { k: 'from $7,500', v: 'Starting investment' },
  { k: '3–5 interviews', v: 'Plus two working sessions & a presentation' },
];
---

<section class="section section--paper-2 review" id="review">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">The Review</p>
      <h2>The Business Operating Model Review.</h2>
      <p class="lead">
        A focused engagement that produces six executive deliverables — clarity, priorities and a roadmap
        for your next significant technology decision.
      </p>
    </div>

    <ol class="deliverables">
      {deliverables.map((d, i) => (
        <li class="deliverable reveal" data-delay={i % 3}>
          <span class="deliverable__n">{d.n}</span>
          <span class="deliverable__title">{d.title}</span>
          <span class="deliverable__desc">{d.desc}</span>
        </li>
      ))}
    </ol>

    <dl class="review__facts reveal">
      {facts.map((f) => (
        <div class="fact">
          <dt>{f.k}</dt>
          <dd>{f.v}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .deliverables {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--line-strong);
  }
  .deliverable {
    display: grid;
    grid-template-columns: 3.5rem minmax(15rem, 22rem) 1fr;
    align-items: baseline;
    gap: 0.5rem 2rem;
    padding: clamp(1.5rem, 2.6vw, 2.1rem) 0;
    border-bottom: 1px solid var(--line);
  }
  .deliverable__n {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--teal);
    letter-spacing: 0.04em;
  }
  .deliverable__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.9vw, 1.5rem);
    color: var(--text-strong);
    letter-spacing: -0.02em;
  }
  .deliverable__desc { color: var(--text-muted); font-size: 1.02rem; }

  .review__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: clamp(3.5rem, 6vw, 5rem) 0 0;
    padding-top: clamp(3rem, 5vw, 4rem);
  }
  .fact dt {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.7rem, 3vw, 2.2rem);
    color: var(--text-strong);
    letter-spacing: -0.02em;
  }
  .fact dd { color: var(--text-muted); font-size: 0.98rem; margin-top: 0.35rem; }

  @media (max-width: 720px) {
    .deliverable {
      grid-template-columns: 2.5rem 1fr;
      gap: 0.35rem 1rem;
    }
    .deliverable__desc { grid-column: 2; }
    .review__facts { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
