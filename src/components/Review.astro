---
const deliverables = [
  { n: '01', title: 'Executive Briefing', desc: 'Findings and recommendations, distilled.', accent: 'teal' },
  { n: '02', title: 'Operating Model Assessment', desc: 'How the business runs today — and where it should evolve.', accent: 'teal' },
  { n: '03', title: 'Capability Assessment', desc: 'What genuinely differentiates you.', accent: 'teal' },
  { n: '04', title: 'AI & Automation Assessment', desc: "Where AI creates measurable value — and where it doesn't.", accent: 'coral' },
  { n: '05', title: 'Build vs. Buy Recommendations', desc: 'Where to build, buy, automate or simplify.', accent: 'teal' },
  { n: '06', title: '12–18 Month Roadmap', desc: 'A prioritized sequence, ordered by business value.', accent: 'coral' },
];

const facts = [
  { k: '2–3 weeks', v: 'Typical engagement' },
  { k: 'from $7,500', v: 'Starting investment' },
  { k: '3–5 interviews', v: 'Plus two working sessions & a presentation' },
];
---

<section class="section section--paper-2 review" id="review">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">The Review</p>
      <h2>The Business Operating Model Review.</h2>
      <p class="lead">
        A focused engagement that produces six executive deliverables — clarity, priorities and a roadmap
        for your next significant technology decision.
      </p>
    </div>

    <div class="review__grid">
      {deliverables.map((d, i) => (
        <article class={`cover cover--${d.accent} reveal`} data-delay={i % 3}>
          <span class="cover__spine" aria-hidden="true"></span>
          <span class="cover__n">{d.n}</span>
          <h3>{d.title}</h3>
          <p>{d.desc}</p>
          <span class="cover__foot">Fyrefish · Executive Deliverable</span>
        </article>
      ))}
    </div>

    <dl class="review__facts reveal">
      {facts.map((f) => (
        <div class="fact">
          <dt>{f.k}</dt>
          <dd>{f.v}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .review__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .cover {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 232px;
    background: var(--ink);
    color: var(--text-on-dark);
    border-radius: var(--radius);
    padding: 1.6rem 1.6rem 1.4rem;
    overflow: hidden;
    border: 1px solid var(--ink-hair);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .cover:hover {
    transform: translateY(-5px);
    box-shadow: 0 22px 44px -22px rgba(9,17,15,0.7);
    border-color: rgba(66,176,170,0.4);
  }
  .cover__spine {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 4px;
    background: var(--teal);
  }
  .cover--coral .cover__spine { background: var(--coral); }
  .cover__n {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--teal-bright);
    margin-bottom: auto;
    letter-spacing: 0.05em;
  }
  .cover--coral .cover__n { color: var(--coral-soft); }
  .cover h3 { color: var(--text-on-dark); font-size: 1.25rem; margin: 1.75rem 0 0.5rem; letter-spacing: -0.01em; }
  .cover p { color: var(--text-on-dark-muted); font-size: 0.98rem; line-height: 1.5; }
  .cover__foot {
    margin-top: 1.25rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--ink-hair);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-on-dark-faint);
  }

  .review__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding-top: clamp(2.5rem, 5vw, 3.5rem);
    border-top: 1px solid var(--line-strong);
  }
  .fact dt {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    color: var(--text-strong);
    letter-spacing: -0.02em;
  }
  .fact dd { color: var(--text-muted); font-size: 0.98rem; margin-top: 0.3rem; }

  @media (max-width: 820px) {
    .review__grid { grid-template-columns: 1fr 1fr; }
    .review__facts { grid-template-columns: 1fr; gap: 1.25rem; text-align: left; }
  }
  @media (max-width: 520px) {
    .review__grid { grid-template-columns: 1fr; }
  }
</style>
