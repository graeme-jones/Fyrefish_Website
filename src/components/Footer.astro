---
import Logo from './Logo.astro';
const CONTACT_EMAIL = 'graeme.jones@fyrefish.com';
const year = 2026; // Build-time constant; bump on redesign.
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <Logo variant="light" />
      <p>Executive clarity before expensive technology decisions.</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <a href="#the-case">The Case</a>
      <a href="#process">Process</a>
      <a href="#findings">Findings</a>
      <a href="#deliverables">Deliverables</a>
      <a href="#get-started">Get Started</a>
    </nav>

    <div class="footer__contact">
      <p class="footer__person">Graeme Jones</p>
      <p class="footer__role">Executive Advisor · Business &amp; Technology Strategy</p>
      <a class="footer__email" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
    </div>
  </div>

  <div class="container footer__bar">
    <span>© {year} Fyrefish Technologies. All rights reserved.</span>
    <span>Delivered by Fyrefish Technologies</span>
  </div>
</footer>

<style>
  .footer { background: var(--ink-2); color: var(--text-on-dark); padding-top: clamp(3rem, 6vw, 4.5rem); }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__brand p { color: var(--text-on-dark-muted); margin-top: 1rem; max-width: 32ch; }
  .footer__nav { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer__nav a { color: var(--text-on-dark-muted); transition: color 0.2s var(--ease); width: fit-content; }
  .footer__nav a:hover { color: var(--text-on-dark); }
  .footer__person { font-family: var(--font-display); font-weight: 700; }
  .footer__role { color: var(--text-on-dark-muted); font-size: 0.92rem; margin-bottom: 0.75rem; }
  .footer__email { color: var(--teal-bright); }
  .footer__email:hover { text-decoration: underline; }

  .footer__bar {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--line-dark);
    color: var(--text-on-dark-muted);
    font-size: 0.85rem;
  }
  @media (max-width: 720px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
