---
import Logo from './Logo.astro';
const CONTACT_EMAIL = 'graeme.jones@fyrefish.com';
const year = 2026; // Build-time constant; bump on redesign.

const nav = [
  { href: '/#why', label: 'Why It Matters' },
  { href: '/#review', label: 'The Review' },
  { href: '/#experience', label: 'Experience' },
  { href: '/knowledge/', label: 'Knowledge' },
  { href: '/#about', label: 'About' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <Logo uid="footer" />
      <p>Executive clarity before expensive technology decisions.</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      {nav.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="footer__contact">
      <p class="footer__person">Graeme Jones</p>
      <p class="footer__role">Executive Advisor · Business &amp; Technology Strategy</p>
      <a class="footer__email" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
    </div>
  </div>

  <div class="container footer__bar">
    <span>© {year} Fyrefish Technologies. All rights reserved.</span>
    <a class="footer__li" href="https://www.linkedin.com/in/graeme-jones-fyrefish" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
  </div>
</footer>

<style>
  .footer { background: var(--ink-2); color: var(--text-on-dark); padding-top: clamp(3.5rem, 6vw, 5rem); }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__brand p { color: var(--text-on-dark-muted); margin-top: 1.1rem; max-width: 30ch; font-size: 0.95rem; }
  .footer__nav { display: flex; flex-direction: column; gap: 0.7rem; }
  .footer__nav a { color: var(--text-on-dark-muted); transition: color 0.2s var(--ease); width: fit-content; }
  .footer__nav a:hover { color: var(--text-on-dark); }
  .footer__person { font-family: var(--font-display); font-weight: 700; }
  .footer__role { color: var(--text-on-dark-muted); font-size: 0.9rem; margin-bottom: 0.8rem; }
  .footer__email { color: var(--teal-bright); }
  .footer__email:hover { text-decoration: underline; }

  .footer__bar {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 1.6rem;
    border-top: 1px solid var(--line-dark);
    color: var(--text-on-dark-faint);
    font-size: 0.85rem;
  }
  .footer__li { color: var(--text-on-dark-muted); }
  .footer__li:hover { color: var(--text-on-dark); }
  @media (max-width: 720px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
