---
const items = [
  { n: '01', title: 'Executive Briefing', body: 'A concise summary of findings and recommendations.' },
  { n: '02', title: 'Operating Model Assessment', body: 'How the business operates today — and where it should evolve.' },
  { n: '03', title: 'Capability Assessment', body: 'The capabilities that truly differentiate the business.' },
  { n: '04', title: 'AI & Automation Assessment', body: "Where AI creates measurable value — and where it doesn't.", accent: true },
  { n: '05', title: 'Build vs. Buy Recommendations', body: 'Clear guidance on where to build, buy, automate or simplify.' },
  { n: '06', title: '12–18 Month Roadmap', body: 'A prioritized sequence of initiatives based on business value.', accent: true },
];
---

<section class="section deliverables" id="deliverables">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Deliverables</p>
      <h2>What You'll Walk Away With</h2>
      <p class="lead">
        Six practical executive deliverables that provide clarity, priorities and a roadmap for future
        decisions.
      </p>
    </div>

    <div class="deliverables__grid">
      {items.map((it) => (
        <article class="deliverable reveal">
          <span class={`deliverable__n${it.accent ? ' deliverable__n--accent' : ''}`}>{it.n}</span>
          <h3>{it.title}</h3>
          <p>{it.body}</p>
        </article>
      ))}
    </div>

    <blockquote class="deliverables__banner reveal">
      <p>The value of this review isn't the documentation.</p>
      <p>It's the quality of the decisions the documentation enables.</p>
    </blockquote>
  </div>
</section>

<style>
  .deliverables__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .deliverable {
    background: var(--paper-2);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2rem);
  }
  .deliverable__n {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2rem;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .deliverable__n--accent { color: var(--coral); }
  .deliverable h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
  .deliverable p { color: var(--text-muted); }

  .deliverables__banner {
    background: var(--ink);
    color: var(--text-on-dark);
    border-radius: var(--radius-lg);
    padding: clamp(2.25rem, 5vw, 3.25rem);
    text-align: center;
    margin: 0;
  }
  .deliverables__banner p {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 2.8vw, 1.6rem);
    line-height: 1.35;
  }
  .deliverables__banner p:first-child { color: var(--text-on-dark); }
  .deliverables__banner p:last-child { color: var(--teal-bright); }

  @media (max-width: 860px) { .deliverables__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .deliverables__grid { grid-template-columns: 1fr; } }
</style>
