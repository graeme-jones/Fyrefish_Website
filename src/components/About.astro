---
const credentials = [
  '30+ years',
  'Ericsson · Global Telecoms',
  'Enterprise Software',
  'Product Strategy',
  'Business Transformation',
];
---

<section class="section about" id="about">
  <div class="container about__grid">
    <div class="about__portrait reveal">
      <figure class="portrait">
        <img
          src="/graeme-jones.jpg"
          alt="Graeme Jones, Executive Advisor at Fyrefish"
          width="896"
          height="1088"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="portrait__cap">Graeme Jones · Executive Advisor</figcaption>
      </figure>
    </div>

    <div class="about__body">
      <p class="eyebrow reveal">About</p>
      <h2 class="reveal" data-delay="1">Three decades turning technology questions into business clarity.</h2>
      <div class="prose reveal" data-delay="1">
        <p>
          Graeme Jones has spent more than thirty years at the intersection of business and technology — from
          global telecoms at Ericsson to enterprise software, product strategy and large-scale business
          transformation.
        </p>
        <p>
          He has led the redesign of enterprise applications used by thousands, operationalized new services
          for major customers, and helped organizations of every size see past the software to the business
          underneath. Fyrefish is the distillation of that experience.
        </p>
      </div>
      <ul class="about__creds reveal" data-delay="2">
        {credentials.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    background: linear-gradient(160deg, var(--ink-3), var(--ink));
    border: 1px solid var(--ink-hair);
    overflow: hidden;
    margin: 0;
    box-shadow: 0 30px 60px -35px rgba(9,17,15,0.6);
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 18%;
  }
  /* Scrim so the caption stays legible over the photo */
  .portrait::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 40%;
    background: linear-gradient(to top, rgba(15,25,23,0.85), transparent);
    pointer-events: none;
  }
  .portrait__cap {
    position: absolute;
    left: 1.25rem; bottom: 1.1rem;
    z-index: 1;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--text-on-dark);
  }

  .about__body h2 { font-size: var(--fs-h2); margin-bottom: 1.5rem; max-width: 20ch; }
  .about__creds {
    list-style: none;
    padding: clamp(1.75rem, 3vw, 2.5rem) 0 0;
    margin: clamp(1.75rem, 3vw, 2.5rem) 0 0;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 550;
    color: var(--text-muted);
  }
  .about__creds li { display: inline-flex; align-items: center; gap: 1.1rem; }
  .about__creds li:not(:last-child)::after {
    content: "";
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--line-strong);
  }

  @media (max-width: 860px) {
    .about__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about__portrait { max-width: 340px; }
  }
</style>
